{
  "name": "cosynq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:properties": "vitest run test/properties",
    "test:integration": "vitest run test/integration",
    "test:unit": "vitest run test/unit",
    "test:smoke": "vitest run test/smoke",
    "perf:check-animations": "node scripts/check-animation-performance.js",
    "perf:audit": "node -e \"console.log('Run: npm run perf:audit:windows (PowerShell) or npm run perf:audit:unix (Bash)')\"",
    "perf:audit:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-performance-tests.ps1",
    "perf:audit:unix": "bash scripts/run-performance-tests.sh",
    "analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "supabase": "^2.89.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "fast-check": "^4.6.0",
